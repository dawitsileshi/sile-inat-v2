# ─── Flask ────────────────────────────────────────────────────────────────────
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=1
LOG_LEVEL=INFO

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-change-in-production-XKCD327

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (use * only in development)
CORS_ORIGINS=*

# ─── Database ─────────────────────────────────────────────────────────────────
# Defaults to SQLite in instance/ — override for PostgreSQL in production:
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/maternal_wellness
